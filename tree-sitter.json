{
  "grammars": [
    {
      "name": "jerboa",
      "camelcase": "Jerboa",
      "scope": "source.jerboa",
      "path": ".",
      "file-types": [
        "ss",
        "sls"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^(jerboa|scheme)$"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Jerboa Scheme",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-jerboa"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
